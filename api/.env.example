# API Server Configuration
PORT=3000
FRONTEND_URL=http://localhost:3000

# Database Configuration
PGUSER=local_pg
PGPASSWORD=local_pg_password
PGHOST=postgres
PGPORT=5432
PGDATABASE=local_pg
PGSSLMODE=disable

# Security & Session
SECRET=your_jwt_secret_key_here
REFRESH_SECRET=your_jwt_refresh_secret_key_here

# Redis Cache Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_USERNAME=
REDIS_SSL=false
