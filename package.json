{
  "name": "agromanager-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "api",
    "web",
    "workers",
    "infra"
  ],
  "scripts": {
    "setup": "npm run setup:env && npm run compose:build",
    "compose:up": "docker compose -f ./docker-compose.yml up",
    "compose:build": "docker compose -f ./docker-compose.yml up --build",
    "compose:stop": "docker compose -f ./docker-compose.yml stop",
    "compose:start": "docker compose -f ./docker-compose.yml start",
    "compose:down": "docker compose -f ./docker-compose.yml down",
    "build": "npm run build -ws --if-present",
    "test": "npm run test -ws --if-present",
    "lint": "npm run lint -ws --if-present",
    "format": "npm run format -ws --if-present",
    "migrate": "node-pg-migrate up --envPath .env.development",
    "setup:env": "node -e \"const f=require('fs');['api','web','workers','infra'].forEach(d=>['development','test','production'].forEach(e=>{const t=d+'/.env.'+e;if(!f.existsSync(t))f.copyFileSync(d+'/.env.example',t)}))\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.2.0",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.22.0"
  },
  "lint-staged": {
    "api/**/*.{ts,tsx}": [
      "eslint --fix",
      "npm run test --workspace=api -- --changed"
    ],
    "web/**/*.{ts,tsx}": [
      "eslint --fix"
    ],
    "workers/**/*.{ts,tsx}": [
      "eslint --fix"
    ],
    "infra/**/*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
